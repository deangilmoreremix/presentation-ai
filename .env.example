# AI Providers (Optional - mock mode works without these)
# OPENAI_API_KEY=""
# TOGETHER_AI_API_KEY=""

# Web Search (Optional)
# TAVILY_API_KEY=""

# Image Generation (Optional)
# FAL_API_KEY=""
# UNSPLASH_ACCESS_KEY=""

# Local AI Models (Optional - runs on localhost)
OLLAMA_BASE_URL="http://localhost:11434"
LM_STUDIO_BASE_URL="http://localhost:1234/v1"

