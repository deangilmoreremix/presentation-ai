# Production Environment Variables
# Copy this file to .env and fill in your production values

# Database
DATABASE_URL="postgresql://postgres:password@db:5432/presentation_ai"

# Authentication
NEXTAUTH_SECRET="your-32-character-secret-here-change-this-in-production"
NEXTAUTH_URL="http://localhost:3000" # Change to your domain when ready

# OAuth Providers
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# AI Services
OPENAI_API_KEY="your-openai-api-key"
TOGETHER_AI_API_KEY="your-together-ai-key"
FAL_API_KEY="your-fal-api-key" # Optional
PINECONE_API_KEY="your-pinecone-key" # Optional

# File Storage
UPLOADTHING_TOKEN="your-uploadthing-token"

# External Services
UNSPLASH_ACCESS_KEY="your-unsplash-access-key"
TAVILY_API_KEY="your-tavily-api-key"

# Production Settings
NODE_ENV="production"
SKIP_ENV_VALIDATION="false"